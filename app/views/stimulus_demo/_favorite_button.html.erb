<button
  data-controller="favorite"
  data-action="favorite#toggle"
  data-favorite-id-param="<%= @content.id %>"
  data-favorite-url-param="<%= stimulus_toggle_path(@content) %>"
  class="inline-flex items-center gap-2 px-4 py-2 rounded-full border transition <%= @content.is_favorite ? "border-rose-300 bg-rose-50" : "border-gray-300 bg-white" %>"
>
  <%# 配下のパーシャルへは locals で値をリレーする %>
  <%= render "heart", content: @content %>

  <span class="text-sm font-medium text-gray-700">
    <%= @content.is_favorite ? "いいね済み" : "いいね" %>
  </span>
</button>
