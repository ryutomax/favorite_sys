<% content_for :title, "Stimulus パターン" %>

<h1 class="text-2xl font-bold mb-1">パターンA: Stimulus アクションパラメータ</h1>
<p class="text-gray-600 mb-8 text-sm">
  ハートを押すと <code>fetch</code> で PATCH 送信し、返ってきた JSON でクライアント側の見た目を更新します。
</p>

<div class="space-y-4">
  <% @contents.each do |content| %>
    <article class="flex items-center justify-between p-5 bg-white rounded-xl border border-gray-200">
      <div>
        <h2 class="font-bold"><%= content.title %></h2>
        <p class="text-sm text-gray-500"><%= content.body %></p>
      </div>

      <button
        data-controller="favorite"
        data-action="favorite#toggle"
        data-favorite-id-param="<%= content.id %>"
        data-favorite-url-param="<%= stimulus_toggle_path(content) %>"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border transition <%= content.is_favarite ? "border-rose-300 bg-rose-50" : "border-gray-300 bg-white" %>"
      >
        <span data-favorite-target="filled" class="text-rose-500 <%= "hidden" unless content.is_favarite %>">
          <%= heart_icon(filled: true) %>
        </span>
        <span data-favorite-target="outline" class="text-gray-400 <%= "hidden" if content.is_favarite %>">
          <%= heart_icon(filled: false) %>
        </span>
        <span data-favorite-target="label" class="text-sm font-medium text-gray-700">
          <%= content.is_favarite ? "いいね済み" : "いいね" %>
        </span>
      </button>
    </article>
  <% end %>
</div>
